@page
@model algotournament.Pages.Duels.CreateModel
@{
    ViewData["Title"] = "duels.create";
}

<div class="page-header">
    <h1 class="page-title"><span class="prompt-symbol">&gt;</span> <span data-i18n="duels.create">create duel</span></h1>
</div>

<div class="duel-panel" style="max-width: 560px;">
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="duel-error"></div>

        <div class="form-group" style="margin-bottom: 1.5rem;">
            <label asp-for="Input.ProblemId" style="font-weight: 700; display: block; margin-bottom: 0.5rem;" data-i18n="problems.title">Problem</label>
            <select asp-for="Input.ProblemId" asp-items="Model.Problems" class="brutalist-input" style="width: 100%;"></select>
            <span asp-validation-for="Input.ProblemId" class="duel-error"></span>
        </div>

        <div class="form-group" style="margin-bottom: 1.5rem;">
            <label style="font-weight: 700; display: block; margin-bottom: 0.5rem;" data-i18n="duels.duration">Duration</label>
            <div class="duel-duration-group">
                @foreach (var duration in Model.DurationOptions)
                {
                    <label class="duel-duration-option">
                        <input type="radio" asp-for="Input.DurationMinutes" value="@duration" />
                        <span>@duration</span> <span data-i18n="duels.minutes">min</span>
                    </label>
                }
            </div>
        </div>

        <button type="submit" class="btn btn-primary" data-i18n="duels.create_room">Create Room</button>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

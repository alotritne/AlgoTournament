@page
@model algotournament.Pages.Duels.CreateModel
@{
    ViewData["Title"] = "duels.create";
}

<div class="page-header">
    <h1 class="page-title"><span class="prompt-symbol">&gt;</span> <span data-i18n="duels.create">create duel</span></h1>
</div>

<div class="duel-panel" style="max-width: 560px;">
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="duel-error"></div>

        <div class="form-group" style="margin-bottom: 1.5rem;">
            <label asp-for="Input.ProblemId" style="font-weight: 700; display: block; margin-bottom: 0.5rem;" data-i18n="problems.title">Problem</label>
            <input type="text" id="problemSearch" class="brutalist-input" style="width: 100%; margin-bottom: 0.5rem;" placeholder="Search problems..." data-i18n-placeholder="common.search" />
            <select asp-for="Input.ProblemId" asp-items="Model.Problems" class="brutalist-input" style="width: 100%;" id="problemSelect"></select>
            <span asp-validation-for="Input.ProblemId" class="duel-error"></span>
        </div>

        <div class="form-group" style="margin-bottom: 1.5rem;">
            <label style="font-weight: 700; display: block; margin-bottom: 0.5rem;" data-i18n="duels.duration">Duration</label>
            <div class="duel-duration-group">
                @foreach (var duration in Model.DurationOptions)
                {
                    <label class="duel-duration-option">
                        <input type="radio" asp-for="Input.DurationMinutes" value="@duration" class="duration-radio" />
                        <span>@duration</span> <span data-i18n="duels.minutes">min</span>
                    </label>
                }
                <label class="duel-duration-option">
                    <input type="radio" asp-for="Input.DurationMinutes" value="0" class="duration-radio" id="customDurationRadio" />
                    <span data-i18n="duels.custom">Custom</span>
                </label>
            </div>
            <div id="customDurationInput" style="display: none; margin-top: 0.5rem;">
                <input type="number" asp-for="Input.DurationMinutes" class="brutalist-input" style="width: 100px;" min="1" max="180" placeholder="Minutes" data-i18n-placeholder="duels.minutes_placeholder" />
                <span data-i18n="duels.minutes">min</span>
            </div>
        </div>

        <button type="submit" class="btn btn-primary" data-i18n="duels.create_room">Create Room</button>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const searchInput = document.getElementById('problemSearch');
            const select = document.getElementById('problemSelect');
            
            searchInput.addEventListener('input', function() {
                const searchTerm = this.value.toLowerCase();
                const options = select.options;
                
                for (let i = 0; i < options.length; i++) {
                    const option = options[i];
                    const text = option.text.toLowerCase();
                    if (text.includes(searchTerm)) {
                        option.style.display = '';
                    } else {
                        option.style.display = 'none';
                    }
                }
            });

            const customDurationRadio = document.getElementById('customDurationRadio');
            const customDurationInput = document.getElementById('customDurationInput');
            const durationRadios = document.querySelectorAll('.duration-radio');
            const durationInput = customDurationInput.querySelector('input');

            customDurationRadio.addEventListener('change', function() {
                if (this.checked) {
                    customDurationInput.style.display = 'block';
                    durationInput.focus();
                    durationInput.value = '';
                }
            });

            durationRadios.forEach(radio => {
                if (radio.id !== 'customDurationRadio') {
                    radio.addEventListener('change', function() {
                        if (this.checked) {
                            customDurationInput.style.display = 'none';
                        }
                    });
                }
            });

            durationInput.addEventListener('input', function() {
                if (this.value) {
                    customDurationRadio.checked = true;
                }
            });
        });
    </script>
}

@page
@model algotournament.Pages.Duels.JoinModel
@{
    ViewData["Title"] = "duels.join_duel";
}

<div class="page-header">
    <h1 class="page-title"><span class="prompt-symbol">&gt;</span> <span data-i18n="duels.join_duel">join duel</span></h1>
</div>

<div class="duel-panel" style="max-width: 560px;">
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="duel-error"></div>

        <div class="form-group" style="margin-bottom: 1.5rem;">
            <label asp-for="Input.RoomCode" style="font-weight: 700; display: block; margin-bottom: 0.5rem;" data-i18n="duels.room_code">Room Code</label>
            <input asp-for="Input.RoomCode" class="brutalist-input duel-room-code-input" maxlength="6" placeholder="AB12CD" style="width: 100%; text-transform: uppercase;" />
            <span asp-validation-for="Input.RoomCode" class="duel-error"></span>
        </div>

        <button type="submit" class="btn btn-primary" data-i18n="duels.join_room">Join Room</button>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="~/js/duel/common.js" asp-append-version="true"></script>
}

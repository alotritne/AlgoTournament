@page
@model algotournament.Pages.Admin.TestCases.CreateModel
@{
    ViewData["Title"] = "admin.create_test_case";
    // Get current language from cookie or default to Vietnamese
    var currentLanguage = Request.Cookies["preferredLanguage"] ?? "vi";
}

<div class="container mt-4">
    <div class="admin-header">
        <h1 data-i18n="admin.create_test_case">Create Test Case for Problem: @(Model.Problem?.GetTitle(currentLanguage) ?? "Unknown")</h1>
    </div>
    
    <div class="admin-form-container">
        <form method="post" asp-route-problemId="@Model.TestCase.ProblemId">
            <div asp-validation-summary="All" class="text-danger"></div>
            <input type="hidden" asp-for="TestCase.ProblemId" />
            
            <div class="form-group mb-3">
                <label asp-for="TestCase.Input" class="control-label" data-i18n="problems.input"></label>
                <textarea asp-for="TestCase.Input" class="form-control" rows="10"></textarea>
                <span asp-validation-for="TestCase.Input" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="TestCase.ExpectedOutput" class="control-label" data-i18n="problems.expected_output"></label>
                <textarea asp-for="TestCase.ExpectedOutput" class="form-control" rows="10"></textarea>
                <span asp-validation-for="TestCase.ExpectedOutput" class="text-danger"></span>
            </div>
            
            <div class="admin-form-row">
                <div class="form-group mb-3">
                    <label asp-for="TestCase.Points" class="control-label" data-i18n="admin.points"></label>
                    <input asp-for="TestCase.Points" class="form-control" type="number" />
                    <span asp-validation-for="TestCase.Points" class="text-danger"></span>
                </div>
                
                <div class="form-group mb-3">
                    <label asp-for="TestCase.Order" class="control-label" data-i18n="admin.order"></label>
                    <input asp-for="TestCase.Order" class="form-control" type="number" />
                    <span asp-validation-for="TestCase.Order" class="text-danger"></span>
                </div>
                
                <div class="form-group mb-3">
                    <div class="form-check mt-4">
                        <input asp-for="TestCase.IsSample" class="form-check-input" />
                        <label asp-for="TestCase.IsSample" class="form-check-label"></label>
                    </div>
                </div>
            </div>
            
            <div class="admin-form-actions">
                <input type="submit" value="Create" class="btn btn-primary" data-i18n="common.create" />
                <a asp-page="Index" asp-route-problemId="@Model.TestCase.ProblemId" class="btn btn-secondary" data-i18n="common.cancel">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
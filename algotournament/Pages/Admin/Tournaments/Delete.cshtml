@page
@model algotournament.Pages.Admin.Tournaments.DeleteModel
@{
    ViewData["Title"] = "admin.delete_tournament";
}

@await Html.PartialAsync("_AdminNavbar")

<div class="container mt-4">
    <h1 data-i18n="admin.delete_tournament">Delete Tournament</h1>
    
    <div class="alert alert-danger">
        <h3 data-i18n="admin.delete_tournament_confirmation">Are you sure you want to delete this tournament?</h3>
        <p data-i18n="admin.delete_tournament_warning">This action cannot be undone. All associated contests will also be deleted.</p>
    </div>
    
    <div class="card">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3" data-i18n="admin.id">ID</dt>
                <dd class="col-sm-9">@Model.Tournament.Id</dd>
                
                <dt class="col-sm-3" data-i18n="common.name">Name</dt>
                <dd class="col-sm-9">@Model.Tournament.Name</dd>
                
                <dt class="col-sm-3" data-i18n="common.description">Description</dt>
                <dd class="col-sm-9">@Model.Tournament.Description</dd>
                
                <dt class="col-sm-3" data-i18n="admin.is_private">Is Private</dt>
                <dd class="col-sm-9">@(Model.Tournament.IsPrivate ? "Yes" : "No")</dd>
                
                <dt class="col-sm-3" data-i18n="admin.is_active">Is Active</dt>
                <dd class="col-sm-9">@(Model.Tournament.IsActive ? "Yes" : "No")</dd>
                
                <dt class="col-sm-3" data-i18n="admin.contests">Contests</dt>
                <dd class="col-sm-9">@Model.Tournament.Contests.Count</dd>
                
                <dt class="col-sm-3" data-i18n="admin.created_at">Created At</dt>
                <dd class="col-sm-9">@Model.Tournament.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>
            </dl>
            
            <form method="post">
                <input type="hidden" asp-for="Tournament.Id" />
                <input type="submit" value="Delete" class="btn btn-danger" data-i18n="common.delete" />
                <a asp-page="Index" class="btn btn-secondary" data-i18n="common.cancel">Cancel</a>
            </form>
        </div>
    </div>
</div>

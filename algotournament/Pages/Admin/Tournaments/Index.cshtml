@page
@model algotournament.Pages.Admin.Tournaments.IndexModel
@{
    ViewData["Title"] = "admin.manage_tournaments";
}

@await Html.PartialAsync("_AdminNavbar")

<div class="container mt-4">
    <div class="admin-header d-flex justify-content-between align-items-center">
        <h1 data-i18n="admin.manage_tournaments">Manage Tournaments</h1>
        <a asp-page="Create" class="btn btn-primary" data-i18n="admin.create_new_tournament">Create New Tournament</a>
    </div>

    <div class="admin-search-bar" style="margin-bottom: 1rem;">
        <input type="text" id="tournamentSearch" class="brutalist-input" style="width: 100%;" placeholder="Search tournaments..." data-i18n-placeholder="admin.search_tournaments_placeholder" onkeyup="filterTournaments()" />
    </div>

    <div class="admin-table-wrapper">
        <table class="table admin-table" id="tournamentsTable">
            <thead>
                <tr>
                    <th data-i18n="admin.id">ID</th>
                    <th data-i18n="common.name">Name</th>
                    <th data-i18n="common.description">Description</th>
                    <th data-i18n="admin.is_private">Is Private</th>
                    <th data-i18n="admin.is_active">Is Active</th>
                    <th data-i18n="admin.contests">Contests</th>
                    <th data-i18n="admin.created_at">Created At</th>
                    <th data-i18n="admin.actions">Actions</th>
                </tr>
            </thead>
            <tbody id="tournamentsTableBody">
                @foreach (var tournament in Model.Tournaments)
                {
                    <tr data-id="@tournament.Id">
                        <td>@tournament.Id</td>
                        <td>@tournament.Name</td>
                        <td>@tournament.Description</td>
                        <td data-i18n="@($"admin.{(tournament.IsPrivate ? "yes" : "no")}")">@(tournament.IsPrivate ? "Yes" : "No")</td>
                        <td data-i18n="@($"admin.{(tournament.IsActive ? "yes" : "no")}")">@(tournament.IsActive ? "Yes" : "No")</td>
                        <td>@tournament.Contests.Count</td>
                        <td>@tournament.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td class="table-actions">
                            <a asp-page="Edit" asp-route-id="@tournament.Id" class="btn btn-sm btn-edit" data-i18n="common.edit">Edit</a>
                            <a asp-page="Delete" asp-route-id="@tournament.Id" class="btn btn-sm btn-delete" data-i18n="common.delete">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        function filterTournaments() {
            const input = document.getElementById('tournamentSearch');
            const filter = input.value.toLowerCase();
            const table = document.getElementById('tournamentsTable');
            const rows = table.getElementsByTagName('tr');

            for (let i = 1; i < rows.length; i++) {
                const cells = rows[i].getElementsByTagName('td');
                let found = false;
                for (let j = 0; j < cells.length; j++) {
                    if (cells[j]) {
                        const textValue = cells[j].textContent || cells[j].innerText;
                        if (textValue.toLowerCase().indexOf(filter) > -1) {
                            found = true;
                            break;
                        }
                    }
                }
                rows[i].style.display = found ? '' : 'none';
            }
        }
    </script>
}

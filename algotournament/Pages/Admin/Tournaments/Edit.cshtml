
@page
@model algotournament.Pages.Admin.Tournaments.EditModel
@{
    ViewData["Title"] = "admin.edit_tournament";
}

@await Html.PartialAsync("_AdminNavbar")

<div class="container mt-4">
    <div class="admin-header">
        <h1 data-i18n="admin.edit_tournament">Edit Tournament</h1>
    </div>
    
    <div class="admin-form-container">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Tournament.Id" />
            
            <div class="form-group mb-3">
                <label asp-for="Tournament.Name" class="control-label" data-i18n="common.name"></label>
                <input asp-for="Tournament.Name" class="form-control" />
                <span asp-validation-for="Tournament.Name" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="Tournament.Description" class="control-label" data-i18n="common.description"></label>
                <textarea asp-for="Tournament.Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Tournament.Description" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="Tournament.SeasonId" class="control-label">Season</label>
                <select asp-for="Tournament.SeasonId" class="form-control" asp-items="Model.SeasonSelectList">
                    <option value="">-- Select Season --</option>
                </select>
                <span asp-validation-for="Tournament.SeasonId" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-3">
                <div class="form-check">
                    <input asp-for="Tournament.IsPrivate" class="form-check-input" />
                    <label asp-for="Tournament.IsPrivate" class="form-check-label" data-i18n="admin.is_private"></label>
                </div>
                <span asp-validation-for="Tournament.IsPrivate" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-3" id="accessCodeGroup" style="display: @(Model.Tournament.IsPrivate ? "block" : "none");">
                <label asp-for="Tournament.AccessCode" class="control-label" data-i18n="admin.access_code"></label>
                <input asp-for="Tournament.AccessCode" class="form-control" />
                <span asp-validation-for="Tournament.AccessCode" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-3">
                <div class="form-check">
                    <input asp-for="Tournament.IsActive" class="form-check-input" />
                    <label asp-for="Tournament.IsActive" class="form-check-label" data-i18n="admin.is_active"></label>
                </div>
                <span asp-validation-for="Tournament.IsActive" class="text-danger"></span>
            </div>
            
            <div class="admin-form-actions">
                <input type="submit" value="Save" class="btn btn-primary" data-i18n="common.save" />
                <a asp-page="Index" class="btn btn-secondary" data-i18n="common.cancel">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.getElementById('Tournament_IsPrivate').addEventListener('change', function() {
            document.getElementById('accessCodeGroup').style.display = this.checked ? 'block' : 'none';
        });
    </script>
}

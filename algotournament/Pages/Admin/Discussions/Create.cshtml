@page
@model algotournament.Pages.Admin.Discussions.CreateModel
@{
    ViewData["Title"] = "admin.create_discussion";
}

@await Html.PartialAsync("_AdminNavbar")

<div class="container mt-4">
    <div class="admin-header">
        <h1 data-i18n="admin.create_discussion">Create Discussion</h1>
    </div>

    <div class="admin-form-container">
        @if (TempData["ErrorMessage"] is string errorMessage)
        {
            <div class="alert alert-warning alert-dismissible fade show" role="alert">
                <strong>Error:</strong> @errorMessage
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["ValidationErrors"] is string validationErrors)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <strong>Validation Errors:</strong> @validationErrors
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="Discussion.Title" class="control-label" data-i18n="discussion.title"></label>
                <input asp-for="Discussion.Title" class="form-control" required />
                <span asp-validation-for="Discussion.Title" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Discussion.Content" class="control-label" data-i18n="discussion.content"></label>
                <textarea asp-for="Discussion.Content" class="form-control" rows="10" required></textarea>
                <span asp-validation-for="Discussion.Content" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Discussion.ProblemId" class="control-label" data-i18n="admin.related_problem">Related Problem (Optional)</label>
                <select asp-for="Discussion.ProblemId" class="form-control" asp-items="Model.Problems">
                    <option value="" data-i18n="admin.none">-- None --</option>
                </select>
            </div>

            <div class="admin-form-actions">
                <input type="submit" value="Create" class="btn btn-primary" data-i18n="common.create" />
                <a asp-page="Index" class="btn btn-secondary" data-i18n="common.cancel">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
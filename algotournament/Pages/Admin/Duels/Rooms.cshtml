@page
@model algotournament.Pages.Admin.Duels.RoomsModel
@{
    ViewData["Title"] = "admin.duel_rooms";
}

@await Html.PartialAsync("_AdminNavbar")

<div class="page-header">
    <h1 class="page-title"><span class="prompt-symbol">&gt;</span> <span data-i18n="duels.rooms">rooms</span></h1>
    <a asp-page="./Index" class="btn btn-secondary" style="margin-left: 1rem;" data-i18n="common.back">Back</a>
</div>

<div class="admin-search-bar" style="margin-bottom: 1rem;">
    <input type="text" id="searchInput" class="brutalist-input" style="width: 100%;" placeholder="Search rooms..." data-i18n-placeholder="common.search" />
</div>

<div class="table-container">
    <table class="brutalist-table">
        <thead>
            <tr>
                <th data-i18n="duels.code">Code</th>
                <th data-i18n="duels.host">Host</th>
                <th data-i18n="problems.title">Problem</th>
                <th data-i18n="submissions.status">Status</th>
                <th data-i18n="admin.duration">Duration</th>
                <th data-i18n="dashboard.created_at">Created</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var room in Model.Rooms)
            {
                <tr>
                    <td style="font-weight:700;">@room.RoomCode</td>
                    <td>@room.HostUser.Handle</td>
                    <td>@room.Problem.TitleVi</td>
                    <td>@room.Status</td>
                    <td>@room.DurationMinutes <span data-i18n="contests.minutes">min</span></td>
                    <td>@room.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const searchInput = document.getElementById('searchInput');
            const table = document.querySelector('.brutalist-table');
            const rows = table.querySelectorAll('tbody tr');

            searchInput.addEventListener('input', function() {
                const searchTerm = this.value.toLowerCase();

                rows.forEach(row => {
                    const text = row.textContent.toLowerCase();
                    if (text.includes(searchTerm)) {
                        row.style.display = '';
                    } else {
                        row.style.display = 'none';
                    }
                });
            });
        });
    </script>
}

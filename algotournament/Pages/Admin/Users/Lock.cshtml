@page
@model algotournament.Pages.Admin.Users.LockModel
@{
    ViewData["Title"] = "admin.lock_user";
}

<div class="container mt-4">
    <h1 data-i18n="admin.lock_user">Lock User</h1>
    
    <div class="alert alert-warning">
        <h3 data-i18n="admin.lock_confirmation">Are you sure you want to lock this user?</h3>
        <p data-i18n="admin.lock_warning">The user will not be able to access the system.</p>
    </div>
    
    <div class="card">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3" data-i18n="admin.handle">Handle</dt>
                <dd class="col-sm-9">@Model.ApplicationUserModel.Handle</dd>
                
                <dt class="col-sm-3" data-i18n="admin.email">Email</dt>
                <dd class="col-sm-9">@Model.ApplicationUserModel.Email</dd>
                
                <dt class="col-sm-3" data-i18n="rankings.rating">Rating</dt>
                <dd class="col-sm-9">@Model.ApplicationUserModel.Rating</dd>
                
                <dt class="col-sm-3" data-i18n="rankings.problems_solved">Problems Solved</dt>
                <dd class="col-sm-9">@Model.ApplicationUserModel.ProblemsSolved</dd>
                
                <dt class="col-sm-3" data-i18n="admin.contests_participated">Contests Participated</dt>
                <dd class="col-sm-9">@Model.ApplicationUserModel.ContestsParticipated</dd>
            </dl>
            
            <form method="post">
                <input type="hidden" asp-for="ApplicationUserModel.Id" />
                <div class="form-group mb-3">
                    <label asp-for="BanReason" class="control-label" data-i18n="admin.ban_reason">Ban Reason</label>
                    <textarea asp-for="BanReason" class="form-control" rows="3" required></textarea>
                    <span asp-validation-for="BanReason" class="text-danger"></span>
                </div>
                
                <input type="submit" value="Lock" class="btn btn-danger" data-i18n="admin.lock" />
                <a asp-page="Index" class="btn btn-secondary" data-i18n="common.cancel">Cancel</a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

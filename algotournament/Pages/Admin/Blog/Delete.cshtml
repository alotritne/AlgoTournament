@page
@model algotournament.Pages.Admin.Blog.DeleteModel
@{
    ViewData["Title"] = "admin.delete_blog_post";
}

<div class="container mt-4">
    <h1 data-i18n="admin.delete_blog_post">Delete Blog Post</h1>

    <div class="alert alert-danger">
        <h3 data-i18n="admin.delete_blog_confirmation">Are you sure you want to delete this blog post?</h3>
    </div>

    <div class="card">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3" data-i18n="admin.id">ID</dt>
                <dd class="col-sm-9">@Model.BlogPost.Id</dd>

                <dt class="col-sm-3" data-i18n="blog.title">Title</dt>
                <dd class="col-sm-9">@Model.BlogPost.Title</dd>

                <dt class="col-sm-3" data-i18n="admin.slug">Slug</dt>
                <dd class="col-sm-9">@Model.BlogPost.Slug</dd>

                <dt class="col-sm-3" data-i18n="discussion.author">Author</dt>
                <dd class="col-sm-9">@Model.BlogPost.Author?.Handle</dd>

                <dt class="col-sm-3" data-i18n="admin.is_public">Published</dt>
                <dd class="col-sm-9">@(Model.BlogPost.IsPublished ? "Yes" : "No")</dd>
            </dl>

            <form method="post">
                <input type="hidden" asp-for="BlogPost.Id" />
                <input type="submit" value="Delete" class="btn btn-danger" data-i18n="common.delete" />
                <a asp-page="Index" class="btn btn-secondary" data-i18n="common.cancel">Cancel</a>
            </form>
        </div>
    </div>
</div>

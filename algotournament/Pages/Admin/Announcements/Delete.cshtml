@page
@model algotournament.Pages.Admin.Announcements.DeleteModel
@{
    ViewData["Title"] = "admin.delete_announcement";
}

@await Html.PartialAsync("_AdminNavbar")

<div class="container mt-4">
    <h1 data-i18n="admin.delete_announcement">Delete Announcement</h1>
    
    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            <strong>Warning:</strong> @errorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    
    <div class="alert alert-danger">
        <h3 data-i18n="admin.delete_confirmation">Are you sure you want to delete this announcement?</h3>
    </div>
    
    <div class="card">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3" data-i18n="admin.id">ID</dt>
                <dd class="col-sm-9">@Model.Announcement.Id</dd>
                
                <dt class="col-sm-3" data-i18n="blog.title">Title</dt>
                <dd class="col-sm-9">@Model.Announcement.Title</dd>
                
                <dt class="col-sm-3" data-i18n="dashboard.name">Creator</dt>
                <dd class="col-sm-9">@Model.Announcement.Creator?.Email</dd>
                
                <dt class="col-sm-3" data-i18n="admin.is_global">Is Global</dt>
                <dd class="col-sm-9">@(Model.Announcement.IsGlobal ? "Yes" : "No")</dd>
                
                <dt class="col-sm-3" data-i18n="admin.tournament">Contest</dt>
                <dd class="col-sm-9">@Model.Announcement.Contest?.Name</dd>
                
                <dt class="col-sm-3" data-i18n="admin.expires_at">Expires At</dt>
                <dd class="col-sm-9">@(Model.Announcement.ExpiresAt?.ToString("yyyy-MM-dd HH:mm") ?? "Never")</dd>
                
                <dt class="col-sm-3" data-i18n="admin.is_active">Is Active</dt>
                <dd class="col-sm-9">@(Model.Announcement.IsActive ? "Yes" : "No")</dd>
                
                <dt class="col-sm-3" data-i18n="dashboard.created_at">Created At</dt>
                <dd class="col-sm-9">@Model.Announcement.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>
            </dl>
            
            <form method="post">
                <input type="hidden" asp-for="Announcement.Id" />
                <input type="submit" value="Delete" class="btn btn-danger" data-i18n="common.delete" />
                <a asp-page="Index" class="btn btn-secondary" data-i18n="common.cancel">Cancel</a>
            </form>
        </div>
    </div>
</div>

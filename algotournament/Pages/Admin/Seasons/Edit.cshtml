@page
@model algotournament.Pages.Admin.Seasons.EditModel
@{
    ViewData["Title"] = "admin.edit_season";
}

@await Html.PartialAsync("_AdminNavbar")

<div class="container mt-4">
    <div class="admin-header">
        <h1 data-i18n="admin.edit_season">Edit Season</h1>
    </div>
    
    <div class="admin-form-container">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Season.Id" />
            
            <div class="form-group mb-3">
                <label asp-for="Season.Name" class="control-label" data-i18n="common.name"></label>
                <input asp-for="Season.Name" class="form-control" />
                <span asp-validation-for="Season.Name" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="Season.Description" class="control-label" data-i18n="common.description"></label>
                <textarea asp-for="Season.Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Season.Description" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="Season.StartDate" class="control-label" data-i18n="admin.start_date"></label>
                <input asp-for="Season.StartDate" class="form-control" type="date" />
                <span asp-validation-for="Season.StartDate" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="Season.EndDate" class="control-label" data-i18n="admin.end_date"></label>
                <input asp-for="Season.EndDate" class="form-control" type="date" />
                <span asp-validation-for="Season.EndDate" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-3">
                <div class="form-check">
                    <input asp-for="Season.IsActive" class="form-check-input" />
                    <label asp-for="Season.IsActive" class="form-check-label" data-i18n="admin.is_active"></label>
                </div>
                <span asp-validation-for="Season.IsActive" class="text-danger"></span>
            </div>
            
            <div class="admin-form-actions">
                <input type="submit" value="Save" class="btn btn-primary" data-i18n="common.save" />
                <a asp-page="Index" class="btn btn-secondary" data-i18n="common.cancel">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

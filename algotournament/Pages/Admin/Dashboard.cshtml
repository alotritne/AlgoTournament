@page
@model DashboardModel
@{
    ViewData["Title"] = "admin.dashboard";
}

@await Html.PartialAsync("_AdminNavbar")

<main class="container">
    <h1 class="page-title" style="margin-bottom: 2rem;"><span class="prompt-symbol">&gt;</span> <span data-i18n="admin.overview">admin::overview</span></h1>
    
    <div class="admin-dashboard-stats" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; margin-bottom: 3rem;">
        <div style="border: var(--border-width) solid var(--text-color); background: #fff; padding: 1.5rem; box-shadow: 4px 4px 0 var(--text-color);">
            <div style="font-weight: 700; text-transform: uppercase; font-size: 0.9rem;" data-i18n="admin.total_users">Total Users</div>
            <div style="font-size: 2.5rem; font-weight: 800; color: var(--accent-color);">@Model.TotalUsers</div>
        </div>
        <div style="border: var(--border-width) solid var(--text-color); background: #fff; padding: 1.5rem; box-shadow: 4px 4px 0 var(--text-color);">
            <div style="font-weight: 700; text-transform: uppercase; font-size: 0.9rem;" data-i18n="admin.active_contests">Active Contests</div>
            <div style="font-size: 2.5rem; font-weight: 800; color: var(--accent-color);">@Model.ActiveContests</div>
        </div>
        <div style="border: var(--border-width) solid var(--text-color); background: #fff; padding: 1.5rem; box-shadow: 4px 4px 0 var(--text-color);">
            <div style="font-weight: 700; text-transform: uppercase; font-size: 0.9rem;" data-i18n="problems.title">Problems</div>
            <div style="font-size: 2.5rem; font-weight: 800; color: var(--accent-color);">@Model.TotalProblems</div>
        </div>
        <div style="border: var(--border-width) solid var(--text-color); background: #fff; padding: 1.5rem; box-shadow: 4px 4px 0 var(--text-color);">
            <div style="font-weight: 700; text-transform: uppercase; font-size: 0.9rem;" data-i18n="admin.submissions_24h">Submissions (24h)</div>
            <div style="font-size: 2.5rem; font-weight: 800; color: var(--accent-color);">@Model.RecentSubmissions</div>
        </div>
    </div>

    <div class="layout-grid" style="grid-template-columns: 1fr 1fr;">
        <section>
            <h3 class="section-title"><span class="prompt-symbol">&gt;</span> <span data-i18n="admin.server_status">server status</span></h3>
            <div style="border: var(--border-width) solid var(--text-color); background: var(--text-color); color: #00ff00; padding: 2rem; font-family: monospace; font-weight: 700;">
                <p>[OK] Database Connection: Connected</p>
                <p>[OK] Judge Queue: @Model.PendingJudges pending</p>
                <p>[OK] System Status: Normal</p>
                <p>[INFO] Uptime: @Model.SystemUptime</p>
            </div>
        </section>
        
        <section>
            <h3 class="section-title"><span class="prompt-symbol">&gt;</span> <span data-i18n="admin.quick_actions">quick actions</span></h3>
            <div style="display: flex; flex-direction: column; gap: 1rem;">
                <a asp-page="./Tournaments/Create" class="btn btn-secondary" data-i18n="admin.create_tournament">+ Create Tournament</a>
                <a asp-page="./Problems/Create" class="btn btn-secondary" data-i18n="admin.create_problem">+ Create Problem</a>
                <a asp-page="./Contests/Create" class="btn btn-secondary" data-i18n="admin.create_contest">+ Create Contest</a>
                <a asp-page="./Discussions/Create" class="btn btn-secondary" data-i18n="admin.create_discussion">+ Create Discussion</a>
                <a asp-page="./Blog/Create" class="btn btn-secondary" data-i18n="admin.create_blog_post">+ Create Blog Post</a>
                <form method="post" asp-page-handler="ClearCache" style="display: inline;">
                    <button type="submit" class="btn btn-secondary" style="width: 100%;" data-i18n="admin.clear_cache">Clear Cache</button>
                </form>
            </div>
        </section>
    </div>
</main>

@page
@model algotournament.Pages.Admin.Contests.DeleteModel
@{
    ViewData["Title"] = "admin.delete_contest";
}

<div class="container mt-4">
    <h1 data-i18n="admin.delete_contest">Delete Contest</h1>
    
    <div class="alert alert-danger">
        <h3 data-i18n="admin.delete_contest_confirmation">Are you sure you want to delete this contest?</h3>
        <p data-i18n="admin.delete_contest_warning">This action cannot be undone. All associated participants and submissions will also be deleted.</p>
    </div>
    
    <div class="card">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3" data-i18n="admin.id">ID</dt>
                <dd class="col-sm-9">@Model.Contest.Id</dd>
                
                <dt class="col-sm-3" data-i18n="common.name">Name</dt>
                <dd class="col-sm-9">@Model.Contest.Name</dd>
                
                <dt class="col-sm-3" data-i18n="admin.tournament">Tournament</dt>
                <dd class="col-sm-9">@Model.Contest.Tournament?.Name</dd>
                
                <dt class="col-sm-3" data-i18n="admin.start_time">Start Time</dt>
                <dd class="col-sm-9">@Model.Contest.StartTime.ToString("yyyy-MM-dd HH:mm")</dd>
                
                <dt class="col-sm-3" data-i18n="admin.end_time">End Time</dt>
                <dd class="col-sm-9">@Model.Contest.EndTime.ToString("yyyy-MM-dd HH:mm")</dd>
                
                <dt class="col-sm-3" data-i18n="admin.duration">Duration</dt>
                <dd class="col-sm-9">@Model.Contest.DurationMinutes minutes</dd>
                
                <dt class="col-sm-3" data-i18n="admin.is_rated">Is Rated</dt>
                <dd class="col-sm-9">@(Model.Contest.IsRated ? "Yes" : "No")</dd>
                
                <dt class="col-sm-3" data-i18n="admin.scoring_mode">Scoring Mode</dt>
                <dd class="col-sm-9">@Model.Contest.ScoringMode</dd>
                
                <dt class="col-sm-3" data-i18n="admin.participants">Participants</dt>
                <dd class="col-sm-9">@Model.Contest.Participants.Count</dd>
            </dl>
            
            <form method="post">
                <input type="hidden" asp-for="Contest.Id" />
                <input type="submit" value="Delete" class="btn btn-danger" data-i18n="common.delete" />
                <a asp-page="Index" class="btn btn-secondary" data-i18n="common.cancel">Cancel</a>
            </form>
        </div>
    </div>
</div>

@page
@model algotournament.Pages.Admin.Contests.IndexModel
@{
    ViewData["Title"] = "admin.manage_contests";
}

@await Html.PartialAsync("_AdminNavbar")

<div class="container mt-4">
    <div class="admin-header d-flex justify-content-between align-items-center">
        <h1 data-i18n="admin.manage_contests">Manage Contests</h1>
        <a asp-page="Create" class="btn btn-primary" data-i18n="admin.create_new_contest">Create New Contest</a>
    </div>

    <div class="admin-table-wrapper">
        <table class="table admin-table">
            <thead>
                <tr>
                    <th data-i18n="admin.id">ID</th>
                    <th data-i18n="common.name">Name</th>
                    <th data-i18n="admin.tournament">Tournament</th>
                    <th data-i18n="admin.start_time">Start Time</th>
                    <th data-i18n="admin.end_time">End Time</th>
                    <th data-i18n="admin.duration">Duration</th>
                    <th data-i18n="admin.is_rated">Is Rated</th>
                    <th data-i18n="admin.scoring_mode">Scoring Mode</th>
                    <th data-i18n="admin.participants">Participants</th>
                    <th data-i18n="admin.actions">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var contest in Model.Contests)
                {
                    <tr>
                        <td>@contest.Id</td>
                        <td>@contest.Name</td>
                        <td>@contest.Tournament?.Name</td>
                        <td>@contest.StartTime.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>@contest.EndTime.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>@contest.DurationMinutes min</td>
                        <td data-i18n="@($"admin.{(contest.IsRated ? "yes" : "no")}")">@(contest.IsRated ? "Yes" : "No")</td>
                        <td>@contest.ScoringMode</td>
                        <td>@contest.Participants.Count</td>
                        <td class="table-actions">
                            <a asp-page="Edit" asp-route-id="@contest.Id" class="btn btn-sm btn-edit" data-i18n="common.edit">Edit</a>
                            <a asp-page="Delete" asp-route-id="@contest.Id" class="btn btn-sm btn-delete" data-i18n="common.delete">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
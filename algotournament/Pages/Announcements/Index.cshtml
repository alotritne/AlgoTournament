@page
@model algotournament.Pages.Announcements.IndexModel
@{
    ViewData["Title"] = "announcements";
}

<div class="page-header">
    <h1 class="page-title"><span class="prompt-symbol">&gt;</span> <span data-i18n="nav.announcements">announcements</span></h1>
</div>

<section>
    @if (Model.Announcements.Any())
    {
        <div class="table-container">
            <table class="brutalist-table">
                <thead>
                    <tr>
                        <th data-i18n="discussion.title">Title</th>
                        <th data-i18n="common.type">Type</th>
                        <th data-i18n="problems.created_at">Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var announcement in Model.Announcements)
                    {
                        <tr>
                            <td>
                                <a asp-page="Detail" asp-route-id="@announcement.Id" style="font-weight: 700;">
                                    @announcement.Title
                                </a>
                            </td>
                            <td>@(announcement.IsGlobal ? "Global" : announcement.Contest?.Name ?? "Contest")</td>
                            <td>@announcement.CreatedAt.ToString("MM/dd/yyyy HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p style="font-weight: 700;" data-i18n="empty.no_announcements_time">No announcements at this time.</p>
    }
</section>

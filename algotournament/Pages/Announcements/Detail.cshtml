@page
@model algotournament.Pages.Announcements.DetailModel
@{
    ViewData["Title"] = Model.Announcement?.Title ?? "Announcement";
}

<div class="page-header">
    <h1 class="page-title"><span class="prompt-symbol">&gt;</span> @(Model.Announcement?.Title ?? "Announcement")</h1>
    @if (Model.Announcement != null)
    {
        <div style="font-weight: 700; margin-top: 0.5rem;">
            <span data-i18n="announcements.posted_on">Posted on</span> @Model.Announcement.CreatedAt.ToString("MM/dd/yyyy HH:mm")
            @if (Model.Announcement.Contest != null)
            {
                <span> | <span data-i18n="announcements.contest">Contest</span>: <a asp-page="/Contests/Detail" asp-route-id="@Model.Announcement.ContestId">@Model.Announcement.Contest.Name</a></span>
            }
        </div>
    }
</div>

@if (Model.Announcement == null)
{
    <p style="font-weight: 700;" data-i18n="announcements.not_found">Announcement not found.</p>
}
else
{
    <div style="background: #fff; padding: 2rem; border: var(--border-width) solid var(--text-color); box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--text-color); margin-bottom: 2rem;">
        @Html.Raw(Model.RenderMarkdown(Model.Announcement.Content))
    </div>

    <a asp-page="Index" class="btn btn-secondary" data-i18n="announcements.back_to_announcements">Back to Announcements</a>
}

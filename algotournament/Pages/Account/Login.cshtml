@page
@model LoginModel
@{
    ViewData["Title"] = "auth.login";
}

<main class="container">
    <div class="auth-container">
        <h1 class="auth-title"><span class="prompt-symbol">&gt;</span> <span data-i18n="auth.login">auth::login</span></h1>
        
        <form method="post">
            <div asp-validation-summary="All" class="text-danger" style="margin-bottom: 1rem;"></div>
            
            <div class="form-group">
                <label asp-for="Input.Email" class="form-label" data-i18n="auth.username_email">Username / Email</label>
                <input asp-for="Input.Email" class="brutalist-input" placeholder="enter handle..." data-i18n-placeholder="auth.enter_handle" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>
            
            <div class="form-group">
                <label asp-for="Input.Password" class="form-label" data-i18n="auth.password">Password</label>
                <input asp-for="Input.Password" class="brutalist-input" type="password" placeholder="********" data-i18n-placeholder="auth.password_placeholder" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>
            
            <div class="form-group">
                <div class="checkbox">
                    <label asp-for="Input.RememberMe">
                        <input asp-for="Input.RememberMe" />
                        <span data-i18n="auth.remember_me">@Html.DisplayNameFor(m => m.Input.RememberMe)</span>
                    </label>
                </div>
            </div>
            
            <button type="submit" class="btn btn-primary btn-block" data-i18n="auth.execute_login">Execute Login</button>
        </form>

        <div class="auth-footer">
            <p><span data-i18n="auth.dont_have_account">Don't have an account?</span> <a asp-page="./Register" data-i18n="auth.register_here">Register here</a>.</p>
            <p><a asp-page="./ForgotPassword" data-i18n="auth.forgot_password">Forgot your password?</a></p>
        </div>
    </div>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
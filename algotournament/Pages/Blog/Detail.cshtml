@page
@model algotournament.Pages.Blog.DetailModel
@{
    ViewData["Title"] = Model.BlogPost?.Title ?? "Blog Post";
}

@if (Model.BlogPost == null)
{
    <div class="page-header">
        <h1 class="page-title"><span class="prompt-symbol">&gt;</span> <span data-i18n="blog.blog_post">blog post</span></h1>
    </div>
    <p style="font-weight: 700;" data-i18n="blog.not_found">Blog post not found.</p>
}
else
{
    <div class="page-header" style="flex-direction: column; align-items: flex-start;">
        <h1 class="page-title"><span class="prompt-symbol">&gt;</span> @Model.BlogPost.Title</h1>
        <div style="font-weight: 700; margin-top: 0.5rem;">
            <span data-i18n="blog.by">By</span> @(Model.BlogPost.Author?.Handle ?? "unknown") <span data-i18n="blog.on">on</span> @Model.BlogPost.PublishedAt.ToString("yyyy-MM-dd HH:mm")
        </div>
    </div>

    <div style="background: #fff; padding: 2rem; border: var(--border-width) solid var(--text-color); box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--text-color); margin-bottom: 2rem;">
        <div class="blog-content">@Model.BlogPost.Content</div>
    </div>

    <a asp-page="Index" class="btn btn-secondary" data-i18n="blog.back_to_blog">Back to Blog</a>
}
